@Metadata.layer: #CUSTOMER

annotate view ZC_SD_IS_LOG2_KAR with
{
  @UI.lineItem: [
    { position: 10, type: #FOR_ACTION, dataAction: 'fetchLogs', label: '새로고침' },
    { position: 20 }
  ]
  StatusIs;

  @UI.lineItem: [{ position: 30 }]
  StatusIn;

  @UI.lineItem: [{ position: 40 }]
  FlowName;

  @UI.lineItem: [{ position: 50 }]
  LastTime;

  @UI.lineItem: [{ position: 60 }]
  InLog;
}